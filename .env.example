# ============================================
# Med-Recallix 环境变量
# 部署时自动 copy 为 .env（见 edgeone.json）
# 本地开发可复制为 .env.local 覆盖
# ============================================

# JWT 签名密钥（Middleware 同步读取，必须通过环境变量提供）
JWT_SECRET=780385f18569b4d35e9d80e233b5cc7e2e25b84c7dda39a962c0c048723fa00d

# AI 模型配置（生产环境写入 KV MED_CONFIG 的 ai_config 记录）
# 以下仅作为本地开发 fallback，KV 优先级高于环境变量
# 支持任何 OpenAI 兼容 API（Moonshot/Kimi、DeepSeek、OpenAI 等）
# KIMI_API_KEY=
# AI_BASE_URL=https://api.moonshot.cn/v1
# AI_MODEL=moonshot-v1-auto

# 本地 KV 存储目录（可选，默认 ~/.med-recallix/）
# MED_RECALLIX_HOME=~/.med-recallix
