# ===========================================
# Med-Recallix — Local Development Environment
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# IMPORTANT: Production AI keys are stored in EdgeOne KV,
# not in environment variables. These are for local dev only.

# AI Configuration
AI_API_KEY=sk-placeholder-replace-with-your-key
AI_BASE_URL=https://api.kimi.com/coding/v1
AI_MODEL=kimi-for-coding

# JWT Secret (auto-generated if not set)
JWT_SECRET=local-dev-secret-change-in-production
